<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register</title>
    <link rel="icon" type="image/png" href="/assets/favicon.ico">
        <!-- bootstrap css -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        <!-- bootstrap css -->
        <link rel="stylesheet" href="style.css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
        <link rel="stylesheet" href="header.css">
        <link rel="stylesheet" href="styles.css">
        <link
        href="https://cdn.jsdelivr.net/npm/remixicon@2.5.0/fonts/remixicon.css"
        rel="stylesheet">
</head>
<body>
    <div class="login registration" id="registration">
        <form action="/sign_up" class="login__form" method="post">
            <h2 class="login__title">Register</h2>
            <p>or register with</p>
            
            <div class="login__group">
            <% include("./partials/messages"); %>
           <div class="social-icons">
             <a href="#" class="icons" id="google-register"
               ><i class="fa-brands fa-google-plus-g" ></i
             ></a>
             <a href="#" class="icons"
               ><i class="fa-brands fa-facebook-f"></i
             ></a>
             <a href="#" class="icons"><i class="fa-brands fa-instagram"></i></a>
             <a href="#" class="icons"><i class="fa-brands fa-twitter"></i></a>
           </div>
    
           <div>
             <label for="name" class="login__label">Full Name</label>
             <input 
             name="name" 
             type="text" 
             placeholder="Name" 
             id="name" 
             class="login__input"
             value="<%= typeof name != 'undefined' ? name : '' %>"
             >
          </div>
           <div>
              <label for="email" class="login__label">Email</label>
              <input 
              name="email" 
              type="email" 
              placeholder="Email" 
              id="email" 
              class="login__input"
              value="<%= typeof email != 'undefined' ? email : '' %>"
              >
           </div>
           
           
           <div class="acc-typeContainer">
             <label for="" class="login__label">Account Type</label>
             <div class="acc-type">
               <div>
                 <input 
                 type="radio" 
                 name="accountType" 
                 id="personal" 
                 value="Scout"
                 >
                 <label for="personal">Scout</label>
               </div>
               <div>
                 <input 
                 type="radio" 
                 name="accountType" 
                 id="business" 
                 value="Player"
                 >
                 <label for="business">Player</label>
               </div>
               <div>
                 <input 
                 type="radio" 
                 name="accountType" 
                 id="other" 
                 value="Team"
                 >
                 <label for="other">Team</label>
               </div>
    
             </div>
           </div>
    
           <div>
              <label for="password" class="login__label">Password</label>
              <input 
              name="password" 
              type="password" 
              placeholder="Password" 
              id="password" 
              class="login__input"
              value="<%= typeof password != 'undefined' ? password : '' %>"
              >
           </div>
           <div>
             <label for="password" class="login__label">Confirm</label>
             <input 
             name="confirmPassword" 
             type="password" 
             placeholder="Confirm Password" 
             id="password" 
             class="login__input"
             value="<%= typeof confirmPassword != 'undefined' ? confirmPassword : '' %>"
             >
          </div>
        </div>
    
        <div>
           <p class="login__signup">
              Already have an account? <a href="#" onclick="alreadyHaveAnAccount()">Log In</a>
           </p>
    
           <button type="submit" class="login__button">Sign Up</button>
        </div>
     </form>
     </div>
     <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script src="main.js"></script>
    <script src="header.js"></script>
    <!-- <script src="index.js"></script> -->

    <!-- bootstrap js -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <!-- bootstrap js -->
</body>
</html>