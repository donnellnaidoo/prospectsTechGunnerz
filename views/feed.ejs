<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Prospects • <%= userName %></title>
  <link rel="stylesheet" href="/feed/feed.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
  <link rel="stylesheet" href="https://unicons.iconscout.com/release/v2.1.6/css/unicons.css" />
  <link rel="stylesheet" href="/public/responsive.css">
  <link
    href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css"
    rel="stylesheet"
/>
  <link rel="icon" type="image/png" href="/assets/favicon.ico">
  <style>
    .search-bar {
        display: flex;
        align-items: center;
    }
    .search-bar input[type="search"] {
        flex: 1;
        padding: 10px;
        font-size: 16px;
    }
    .search-bar button {
        padding: 10px;
        cursor: pointer;
    }
    .usersFound {
        margin-top: 20px;
    }
    .usersFound ul {
        list-style: none;
        padding: 0;
    }
    .usersFound li {
        padding: 10px;
        border-bottom: 1px solid #ccc;
    }
</style>
</head>
<body>
  <!-- ....................NAVIGATION BAR......................... -->
  <nav>
    <div class="nav-container">
      <h2 class="logo"><a href="/feed">Prospects</a></h2>
      <div class="search-bar">
        <div class="search-container">
        <i class="uil uil-search searchIcon"></i>
        <input type="search" placeholder="search" id="nav-search" oninput="searchNavUsers()"/>
        </div>
        <div id="searchResultsNav" class="list-group mt-2"></div>
      </div>
    </div>
  </nav>
  <main>
    <div class="container">
      <div class="left">
        <!-- Side Bar -->
        <div class="profile">
          <div class="profile-picture">
            <img src="/uploads/<%= profilePicture %>" alt="Profile Picture">
          </div>
          <div class="handle">
            <h4><a href="/profile/<%= user %>"><%= userName %></a></h4>
            <p class="text-muted">@<%= accountType %></p>
          </div>
        </div>
        <div class="sidebar">
          <a href="/feed" class="menu-item active" id="home">
            <span><i class="uil uil-home side-icon"></i></span>
            <h3>Home</h3>
          </a>
          <a href="/explore" class="menu-item" id="explore">
            <span><i class="uil uil-compass side-icon"></i></span>
            <h3>Explore</h3>
          </a>
          <a href="/training" class="menu-item" id="training">
            <span><i class="uil uil-football side-icon"></i></span>
            <h3>Training</h3>
          </a>
          <a href="/analytics" class="menu-item" id="analytics">
            <span><i class="uil uil-analytics side-icon"></i></span>
            <h3>Analytics</h3>
          </a>
          <a class="menu-item" id="theme">
            <span><i class="uil uil-palette side-icon"></i></span>
            <h3>Theme</h3>
          </a>
          <a class="menu-item" id="create">
            <span><i class="uil uil-plus-circle side-icon"></i></span>
            <h3>Create</h3>
          </a>
          <br>
          <br>
          <br>
          <br>
          <br>
          <br>
          <br>
          <br>
          <br>
          <br>
          <br>
          <br>
          <a href="/logout" class="menu-item" id="settings">
            <span><i class="uil uil-sign-out-alt side-icon"></i></span>
            <h3>Log Out</h3>
          </a>
        </div>
      </div>
      <!-- END OF LEFT -->

      <!-- MIDDLE -->
      <div class="middle all-posts">
        
        <% posts.forEach(post => { 
          const fileExtension = post.image.split('.').pop().toLowerCase();
      %>
        <div class="contents-post">
          <div class="post">
            <div class="post-header">
              <img class="profile-picture" src="/uploads/<%= post.user.profilePicture %>">
      
              <p class="post-author"><%= post.user.name %></p>
              <!-- <a href="/follow">Follow</a> -->
              <div class="post-menu">
                <i class="uil uil-ellipsis-h" onclick="toggleMenu(this)"></i>
                <div class="menu-content">
                  <a href="#" onclick="editPost('<%= post._id %>', '<%= post.content %>')">Edit</a>
                  <a href="#" onclick="deletePost('<%= post._id %>')">Delete</a>
                  <a href="#">Share</a>
                  <a href="#">Report</a>
                </div>
              </div>
            </div>
            <div class="post-image">
              <% if (fileExtension === 'mp4' || fileExtension === 'webm') { %>
                <video controls style="width: 100%; height: auto;">
                  <source src="/uploads/<%= post.image %>" type="video/<%= fileExtension %>">
                  Your browser does not support the video tag.
                </video>
              <% } else { %>
                <img src="/uploads/<%= post.image %>" alt="Post Image" style="width: 100%; height: auto;">
              <% } %>
            </div>
            <div class="post-content interact">
              <div class="post-content">
                <i class="uil uil-heart"></i>
                <i class="uil uil-share"></i>
                <i class="uil uil-bookmark-full save"></i>
              </div>
            </div>
            <div class="post-content">
              <p><%= post.content %></p>
            </div>
            <div class="post-details">
            </div>
          </div>
        </div>
      <% }); %>
      
      </div>
      <!-- RIGHT SECTION -->
      <div class="right">
        <div class="messages">
          <div class="container">
            <div class="row">
              <div class="col-md-12">
                <input type="text" id="searchBox" class="form-control" placeholder="Search for users..." oninput="searchUsers()">
                <div id="searchResults" class="list-group mt-2"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <!-- ............THEME CUSTOMIZATION -->
  <div class="customize-theme" id="themeBlock">
    <div class="card">
      <h2>Customize Your View</h2>
      <p>Manage your background.</p>
      <div class="background">
        <div class="choose-bg">
          <div class="bg-1 active">
            <span></span>
            <h5 for="bg-1">Light</h5>
          </div>
          <div class="bg-2">
            <span></span>
            <h5 for="bg-2">Lights Out</h5>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal for Creating Posts -->
  <div id="createPostModal" class="modal">
    <div class="modal-content">
        <span class="close">&times;</span>
        <h2>Create Post</h2>
        <form id="createPostForm">
            <textarea id="postContent" placeholder="What's on your mind?" required></textarea>
            <div class="image-preview" id="imagePreview">
                <img src="" alt="Image Preview" class="image-preview__image">
                <span class="image-preview__default-text">Image Preview</span>
            </div>
            <input class="postImageBtn" type="file" id="postImage" accept="image/*,video/*,.gif">
            <!-- Call createPost() function on form submission -->
            <button class="post-button" onclick="createPost(event)" type="submit">Post</button>
        </form>
    </div>
</div>

  </div>


  <script src="/feed/feed.js"></script>
  <script src="/feed/navSearch.js"></script>
  <script>
   async function searchUsers() {
    const searchTerm = document.getElementById('searchBox').value;
    const resultsContainer = document.getElementById('searchResults');
    resultsContainer.innerHTML = ''; // Clear previous results

    if (searchTerm.length < 2) {
      return; // Only search if the term is at least 2 characters long
    }

    try {
      const response = await fetch(`/api/search?q=${encodeURIComponent(searchTerm)}`);
      const users = await response.json();

      if (users.length === 0) {
        resultsContainer.innerHTML = '<p class="list-group-item">No users found</p>';
      } else {
        users.forEach(user => {
          const userItem = document.createElement('a');
          userItem.href = `/profile/${user._id}`;
          userItem.classList.add('list-group-item', 'list-group-item-action');
          
          // Construct the image URL from '/uploads'
          const profilePictureUrl = user.profilePicture ? `/uploads/${user.profilePicture}` : 'default-profile-pic-url';

          userItem.innerHTML = `
            <img src="${profilePictureUrl}" alt="${user.name}">
            <div class="user-info">
              <span class="user-name">${user.name}</span>
              <span class="user-email">${user.email}</span>
            </div>
          `;

          resultsContainer.appendChild(userItem);
        });
      }
    } catch (error) {
      console.error('Error fetching users:', error);
    }
  }
  </script>
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
  <script>
     function deletePost(postId) {
    console.log("Deleting post with ID:", postId); // Log the postId being deleted
    if (confirm("Are you sure you want to delete this post?")) {
        fetch(`/deletePost/${postId}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
        })
        .then(response => {
            console.log("Response status:", response.status); // Log the response status
            if (!response.ok) {
                // Check if the response is JSON, if not, throw an error with the response status
                if (response.headers.get('content-type') && response.headers.get('content-type').includes('application/json')) {
                    return response.json().then(errorData => {
                        throw new Error(errorData.message || 'Failed to delete post');
                    });
                } else {
                    throw new Error('Failed to delete post. Server returned non-JSON response');
                }
            }
            return response.json();
        })
        .then(data => {
            console.log("Response data:", data); // Log the response data
            alert(data.message);
            // Assuming the post element has an id of `post-${postId}`
            const deletedPostElement = document.getElementById(`post-${postId}`);
            if (deletedPostElement) {
                deletedPostElement.remove(); // Remove the post element from the DOM
            }
            // Reload the page after the post is successfully deleted
            location.reload();
        })
        .catch(error => {
            console.error("Error deleting post:", error); // Log any errors
            alert(`Error deleting post: ${error.message}`);
            console.error("Server error response:", error.response.data); // Log server error response
        });
    }
}

  const createPostBtn = document.getElementsByClassName("post-button");
  // Function to create a new post
async function createPost(event) {
    event.preventDefault(); // Prevent the default form submission behavior

    // Get post content and image data
    const postContent = document.getElementById("postContent").value;
    const postImage = document.getElementById("postImage").files[0];

    // Perform asynchronous operation to create the post
    try {
        const formData = new FormData();
        formData.append('postContent', postContent);
        formData.append('postImage', postImage);

        const response = await fetch('/createPost', {
            method: 'POST',
            body: formData
        });

        if (response.ok) {
            // Reload the page after successful post creation
            location.reload();
        } else {
            console.error('Failed to create post.');
            // Handle error if needed
        }
    } catch (error) {
        console.error('Error creating post:', error);
        // Handle error if needed
    }
}


function reloadPage() {
    location.reload();
    window.scrollTo(0, 0); // Scroll to the top of the page
}

  </script>


  
  
</body>
</html>
