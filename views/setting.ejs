<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Prospects</title>
    <link rel="stylesheet" href="/feed/feed.css" />
    <link
      rel="stylesheet"
      href="https://unicons.iconscout.com/release/v2.1.6/css/unicons.css"
    />
  </head>
  <body>
    <!-- ....................NAVIGATION BAR......................... -->
    <nav>
      <div class="nav-container">
        <h2 class="logo"><a href="/feed">Prospects</a></h2>
        <div class="search-bar">
          <i class="uil uil-search"></i>
          <input type="search" placeholder="search" />
        </div>
      </div>
    </nav>
    <main>
      <div class="container">
        <div class="left">
          <!-- Side Bar -->
          <div class="sidebar">
            <a href="/feed" class="menu-item active" id="home">
              <span><i class="uil uil-home side-icon"></i></span>
              <h3>Home</h3>
            </a>
            <a href="/explore" class="menu-item" id="explore">
              <span><i class="uil uil-compass side-icon"></i></span>
              <h3>Explore</h3>
            </a>
            <a href="/training" class="menu-item" id="training">
              <span><i class="uil uil-football side-icon"></i></span>
              <h3>Training</h3>
            </a>
            <a href="/messaging" class="menu-item no-style" id="messages" href="/feed/messaging">
              <span><i class="uil uil-envelope side-icon"></i></span>
              <h3>Messages</h3>
            </a>
            <a href="/analytics" class="menu-item" id="analytics">
              <span><i class="uil uil-analytics side-icon"></i></span>
              <h3>Analytics</h3>
            </a>
            <a class="menu-item" id="theme">
              <span><i class="uil uil-palette side-icon"></i></span>
              <h3>Theme</h3>
            </a>
            <a href="/settings" class="menu-item" id="settings">
              <span><i class="uil uil-setting side-icon"></i></span>
              <h3>Settings</h3>
            </a>
            <a href="/create" class="menu-item" id="create">
              <span><i class="uil uil-palette side-icon"></i></span>
              <h3>Create</h3>
            </a>
          </div>
        </div>
        <!-- END OF LEFT -->

        <!-- MIDDLE -->
        <div class="middle">
          <div class="profile-header">
            <div class="profile-picture">
              <img src="https://www.sheknows.com/wp-content/uploads/2023/09/jason-derulo.jpg?w=1440" alt="Profile Picture">
            </div>
            <div class="profile-info">
              <h1><%= userName %></h1>
              <p>King of life bruhv.</p>
            </div>
          </div>
          <div class="profile-stats">
            <div>
              <strong>100</strong> posts
            </div>
            <div>
              <strong>100k</strong> followers
            </div>
            <div>
              <strong>100</strong> following
            </div>
          </div>
          <div class="profile-posts">
            <img class="post" src="https://www.sheknows.com/wp-content/uploads/2023/09/jason-derulo.jpg?w=1440" alt="Post 1">
            <img class="post" src="https://www.sheknows.com/wp-content/uploads/2023/09/jason-derulo.jpg?w=1440" alt="Post 2">
            <img class="post" src="https://www.sheknows.com/wp-content/uploads/2023/09/jason-derulo.jpg?w=1440" alt="Post 3">
            <img class="post" src="https://www.sheknows.com/wp-content/uploads/2023/09/jason-derulo.jpg?w=1440" alt="Post 1">
            <img class="post" src="https://www.sheknows.com/wp-content/uploads/2023/09/jason-derulo.jpg?w=1440" alt="Post 2">
            <img class="post" src="https://www.sheknows.com/wp-content/uploads/2023/09/jason-derulo.jpg?w=1440" alt="Post 3">
            <img class="post" src="https://www.sheknows.com/wp-content/uploads/2023/09/jason-derulo.jpg?w=1440" alt="Post 1">
            <img class="post" src="https://www.sheknows.com/wp-content/uploads/2023/09/jason-derulo.jpg?w=1440" alt="Post 2">
            <img class="post" src="https://www.sheknows.com/wp-content/uploads/2023/09/jason-derulo.jpg?w=1440" alt="Post 3">
            <!-- Repeat for more posts -->
          </div>
          <div id="myModal" class="modal">
            <span class="close">&times;</span>
            <img class="modal-content" id="img01">
          </div>
        </div>
      </main>
      <!-- ............THEME CUSTOMIZATION -->
      <div class="customize-theme" id="themeBlock">
        <div class="card">
          <h2>Customize Your View</h2>
          <p>Manage your background.</p>
          <div class="background">
            <div class="choose-bg">
              <div class="bg-1 active">
                <span></span>
                <h5>Light</h5>
              </div>
              <div class="bg-2">
                <span></span>
                <h5>Lights Out</h5>
              </div>
            </div>
          </div>
        </div>
      </div>
      <script src="/feed/feed.js"></script>
      <script src="/feed/darkmode.js"></script>
      <script>
        // // Get the modal
        // var modal = document.getElementById("myModal");

        // // Get the posts
        // var posts = document.getElementsByClassName("post");

        // // Get the image and insert it inside the modal
        // var modalImg = document.getElementById("img01");

        // // Loop through all posts and attach a click event listener to each one
        // for (var i = 0; i < posts.length; i++) {
        //   posts[i].addEventListener("click", function() {
        //     modal.style.display = "block";
        //     modalImg.src = this.src;
        //   });
        // }

        // // Get the <span> element that closes the modal
        // var span = document.getElementsByClassName("close")[0];

        // // When the user clicks on <span> (x), close the modal
        // span.onclick = function() { 
        //   modal.style.display = "none";
        // }
        // Get the modal
        var modal = document.getElementById("myModal");

        // Get the posts
        var posts = document.getElementsByClassName("post");

        // Get the image and insert it inside the modal
        var modalImg = document.getElementById("img01");

        // Loop through all posts and attach a click event listener to each one
        for (var i = 0; i < posts.length; i++) {
          posts[i].addEventListener("click", function() {
            modal.style.display = "block";
            modalImg.src = this.src;
          });
        }

        // Get the <span> element that closes the modal
        var span = document.getElementsByClassName("close")[0];

        // When the user clicks on <span> (x), close the modal
        span.onclick = function() { 
          modal.style.display = "none";
        }

        // When the user clicks anywhere outside of the image, close the modal
        modal.onclick = function(event) {
          if (event.target !== modalImg) {
            modal.style.display = "none";
          }
        }

      </script>
    </main>
  </body>
</html>
