  <script src="/feed/feed.js"></script>
  <script src="/feed/navSearch.js"></script>
  <script>
    async function searchUsers() {
     const searchTerm = document.getElementById('searchBox').value;
     const resultsContainer = document.getElementById('searchResults');
     resultsContainer.innerHTML = ''; // Clear previous results
 
     if (searchTerm.length < 2) {
       return; // Only search if the term is at least 2 characters long
     }
 
     try {
       const response = await fetch(`/api/search?q=${encodeURIComponent(searchTerm)}`);
       const users = await response.json();
 
       if (users.length === 0) {
         resultsContainer.innerHTML = '<p class="list-group-item">No users found</p>';
       } else {
         users.forEach(user => {
           const userItem = document.createElement('a');
           userItem.href = `/profile/${user._id}`;
           userItem.classList.add('list-group-item', 'list-group-item-action');
           
           // Construct the image URL from '/uploads'
           const profilePictureUrl = user.profilePicture ? `/uploads/${user.profilePicture}` : 'default-profile-pic-url';
 
           userItem.innerHTML = `
             <img src="${profilePictureUrl}" alt="${user.name}">
             <div class="user-info">
               <span class="user-name">${user.name}</span>
               <span class="user-email">${user.email}</span>
             </div>
           `;
 
           resultsContainer.appendChild(userItem);
         });
       }
     } catch (error) {
       console.error('Error fetching users:', error);
     }
   }
   </script>
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
  <script>
     function deletePost(postId) {
    console.log("Deleting post with ID:", postId); // Log the postId being deleted
    if (confirm("Are you sure you want to delete this post?")) {
        fetch(`/deletePost/${postId}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
        })
        .then(response => {
            console.log("Response status:", response.status); // Log the response status
            if (!response.ok) {
                // Check if the response is JSON, if not, throw an error with the response status
                if (response.headers.get('content-type') && response.headers.get('content-type').includes('application/json')) {
                    return response.json().then(errorData => {
                        throw new Error(errorData.message || 'Failed to delete post');
                    });
                } else {
                    throw new Error('Failed to delete post. Server returned non-JSON response');
                }
            }
            return response.json();
        })
        .then(data => {
            console.log("Response data:", data); // Log the response data
            alert(data.message);
            // Assuming the post element has an id of `post-${postId}`
            const deletedPostElement = document.getElementById(`post-${postId}`);
            if (deletedPostElement) {
                deletedPostElement.remove(); // Remove the post element from the DOM
            }
            // Reload the page after the post is successfully deleted
            location.reload();
        })
        .catch(error => {
            console.error("Error deleting post:", error); // Log any errors
            alert(`Error deleting post: ${error.message}`);
            console.error("Server error response:", error.response.data); // Log server error response
        });
    }
}

  const createPostBtn = document.getElementsByClassName("post-button");
  // Function to create a new post
async function createPost(event) {
    event.preventDefault(); // Prevent the default form submission behavior

    // Get post content and image data
    const postContent = document.getElementById("postContent").value;
    const postImage = document.getElementById("postImage").files[0];

    // Perform asynchronous operation to create the post
    try {
        const formData = new FormData();
        formData.append('postContent', postContent);
        formData.append('postImage', postImage);

        const response = await fetch('/createPost', {
            method: 'POST',
            body: formData
        });

        if (response.ok) {
            // Reload the page after successful post creation
            location.reload();
        } else {
            console.error('Failed to create post.');
            // Handle error if needed
        }
    } catch (error) {
        console.error('Error creating post:', error);
        // Handle error if needed
    }
}


function reloadPage() {
    location.reload();
    window.scrollTo(0, 0); // Scroll to the top of the page
}

  </script>
  <script>
    // Get data from backend
    const userCreatedAt = new Date('<%= userCreatedAt %>');
    const userPostsCount = '<%= userPostsCount %>';
  
    // User activity chart data
    const userActivityData = {
      labels: ['Lifetime', 'Last 30 Days'],
      datasets: [{
        label: 'User Activity',
        data: [userPostsCount, /* Calculate posts in last 30 days */,],
        backgroundColor: [
          'rgba(255, 99, 132, 0.2)',
          'rgba(54, 162, 235, 0.2)',
        ],
        borderColor: [
          'rgba(255, 99, 132, 1)',
          'rgba(54, 162, 235, 1)',
        ],
        borderWidth: 1
      }]
    };

    
  
    // Create User Activity Chart
    const userActivityChart = new Chart(document.getElementById('userActivityChart'), {
      type: 'bar',
      data: userActivityData,
      options: {
        scales: {
          yAxes: [{
            ticks: {
              beginAtZero: true
            }
          }]
        }
      }
    });


  </script>
